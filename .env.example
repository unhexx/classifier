# Пример конфигурации для локального запуска
DATABASE_URL=sqlite:///./data/classifier.db

# Веса классификатора (опционально)
WEIGHT_KEYWORD=0.35
WEIGHT_FUZZY=0.40
WEIGHT_TRIGRAM=0.25
WEIGHT_EMBEDDING=0.0

# Включить тяжёлые embeddings (требует pip install ".[full]" + первая загрузка модели)
ENABLE_EMBEDDINGS=false

DEFAULT_TOP_K=5
DEFAULT_MIN_CONFIDENCE=0.25
MAX_CONTEXT_LENGTH=8000

# Журнал классификаций
ENABLE_CLASSIFICATION_LOGGING=true
HISTORY_MAX_ENTRIES=100

LOG_LEVEL=INFO
